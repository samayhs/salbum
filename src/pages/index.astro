---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ReviewCard from '../components/ReviewCard.astro';
import LastFm from '../components/LastFm.astro';
import MyRotation from '../components/MyRotation.astro';

const reviews = (await getCollection('reviews')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<Base title="salbum">
  <LastFm />

  <div class="section">
    <span class="stamp">№ 01</span>
    <h2>Latest reviews</h2>
    <div class="rule"></div>
  </div>

  <div class="review-grid">
    {reviews.map((r) => <ReviewCard entry={r} featured={r.data.featured} />)}
  </div>

  <MyRotation />
</Base>
