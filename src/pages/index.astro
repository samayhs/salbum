---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ReviewCard from '../components/ReviewCard.astro';
import ListCard from '../components/ListCard.astro';
import LastFm from '../components/LastFm.astro';
import MyRotation from '../components/MyRotation.astro';

const reviews = (await getCollection('reviews')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const lists = (await getCollection('lists')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestList = lists[0];
---
<Base title="salbum">
  <LastFm />

  <MyRotation />

  <div class="section">
    <span class="stamp">№ 01</span>
    <h2>Latest reviews</h2>
    <div class="rule"></div>
  </div>

  <div class="review-grid">
    {reviews.map((r) => <ReviewCard entry={r} featured={r.data.featured} />)}
  </div>

  {latestList && (
    <>
      <div class="section">
        <span class="stamp">№ 02</span>
        <h2>The lists</h2>
        <div class="rule"></div>
      </div>
      <ListCard entry={latestList} limit={8} />
    </>
  )}
</Base>
