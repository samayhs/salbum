---
import '../styles/global.css';
const { title = 'salbum', description = 'A music blog.' } = Astro.props;
const path = Astro.url.pathname;
const isCurrent = (p) => path === p || (p !== '/' && path.startsWith(p));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="room">
      <div class="page stitched-bold">
        <div class="above-stitch">
          <header class="masthead">
            <h1>
              <a href="/" style="color:inherit;text-decoration:none;" aria-label="salbum">
                s<span class="ast" aria-hidden="true"><svg viewBox="-50 -50 100 100" xmlns="http://www.w3.org/2000/svg">
                  <g stroke="var(--stitch)" stroke-width="10" stroke-linecap="round" fill="none">
                    <line x1="-30" y1="2" x2="30" y2="-3"/>
                    <line x1="-14" y1="-26" x2="18" y2="24"/>
                    <line x1="-18" y1="26" x2="16" y2="-24"/>
                  </g>
                </svg></span>lbum
              </a>
            </h1>
            <div class="masthead-sub">A mus*c bl*g · est. 2026</div>
          </header>

          <nav class="nav" aria-label="Primary">
            <a href="/" aria-current={path === '/' ? 'page' : undefined}>H*me</a>
            <a href="/reviews/" aria-current={isCurrent('/reviews') ? 'page' : undefined}>Rev*ews</a>
            <a href="/lists/" aria-current={isCurrent('/lists') ? 'page' : undefined}>Lists</a>
            <a href="/about/" aria-current={isCurrent('/about') ? 'page' : undefined}>About</a>
          </nav>

          <main>
            <slot />
          </main>

          <footer class="foot">
            <span>K*ll the algor*thm</span>
            <span>links // w*ll // @goh*re</span>
          </footer>
        </div>
      </div>
    </div>
  </body>
</html>
